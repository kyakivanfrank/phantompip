# Phantompip Platform - Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!

# ==============================================================================
# CRITICAL: Required for production - will fail deployment without these
# ==============================================================================

# Upstash Redis Configuration (for data persistence)
# Get these from your Upstash Redis dashboard
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Encryption Key (for MT5 password encryption)
# Generate a strong random key - min 32 characters, mix of special chars
# Example: openssl rand -base64 32
ENCRYPTION_KEY=your_strong_encryption_key_here_min_32_chars

# ==============================================================================
# Application Configuration
# ==============================================================================

# Node environment
NODE_ENV=production

# API URL (used by frontend for API calls)
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com

# Session management
# Session expiry in seconds (default: 86400 = 24 hours)
SESSION_EXPIRY=86400

# Session cookie domain (optional, for subdomain sharing)
# Leave empty for default behavior
SESSION_COOKIE_DOMAIN=

# ==============================================================================
# Admin Account Configuration
# ==============================================================================

# Admin email for initial setup
ADMIN_EMAIL=Mukisamicheal088@gmail.com

# Admin plain password (will be hashed on init)
# This should be changed after first login
# Minimum requirements: 8 chars, uppercase, lowercase, number, special char
ADMIN_PASSWORD_PLAIN=H7#xF!9t$mKQ2w5v

# ==============================================================================
# Optional: Payment Gateway Integration
# ==============================================================================

# USDT-TRC20 Wallet Address
USDT_WALLET_ADDRESS=

# MTN Mobile Money Merchant Code
MTN_MERCHANT_CODE=

# Airtel Merchant Code
AIRTEL_MERCHANT_CODE=

# ==============================================================================
# Optional: Email Configuration (for future notifications)
# ==============================================================================

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@phantompip.com

# ==============================================================================
# Optional: Analytics & Monitoring
# ==============================================================================

# Error tracking (Sentry, etc.)
SENTRY_DSN=

# Analytics service
ANALYTICS_ID=

# ==============================================================================
# IMPORTANT SECURITY NOTES
# ==============================================================================
# 1. NEVER commit .env.local to git - it's listed in .gitignore
# 2. Rotate ENCRYPTION_KEY periodically and securely
# 3. Use strong, unique ADMIN_PASSWORD_PLAIN - change after first login
# 4. In production, use environment variables through your hosting platform
# 5. Upstash Redis tokens must be kept secret
# 6. All API calls include 'credentials: include' for secure session handling
# ==============================================================================

# Environment Validation
# The app will validate these variables on startup and fail fast if required
# values are missing or invalid. Check server logs for validation errors.
