# ============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local for local development
# For production (Vercel), set these in: https://vercel.com/dashboard
# ============================================================================

# ============================================================================
# REQUIRED - API Configuration
# ============================================================================


# ============================================================================
# REQUIRED - Redis Database (get from https://console.upstash.com)
# ============================================================================

UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ============================================================================
# REQUIRED - Encryption (generate with: openssl rand -base64 32)
# ============================================================================

ENCRYPTION_KEY=your_strong_encryption_key_min_32_chars
IV_LENGTH=16

# ============================================================================
# REQUIRED - Session Configuration
# ============================================================================

SESSION_SECRET=your-session-secret-key-min-32-chars
SESSION_EXPIRY=86400
NODE_ENV=production

# ============================================================================
# REQUIRED - Admin Account (change before first deployment)
# ============================================================================

ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD_PLAIN=ChangeMe123!@#

# ============================================================================
# REQUIRED - Payment Configuration
# ============================================================================

USDT_WALLET_ADDRESS=TPkbbmZfewcqcUzSG4Vfx6oFD1jUpMGCQK
MTN_MERCHANT_CODE=745979
AIRTEL_MERCHANT_CODE=7104191

# ============================================================================
# OPTIONAL - Email Configuration
# ============================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@phantompip.com


